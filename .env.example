# Copy to `.env.local` and fill from Firebase Console → Project settings → Your apps (Web).
# `VITE_FIREBASE_STORAGE_BUCKET` must match the bucket shown there (often `your-project-id.appspot.com`).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: passcode for admin / barber after Google sign-in (default in code: 5500)
# VITE_ADMIN_PASSCODE=

# After copying to `.env.local`, run `npm run build` — `USE_FIRESTORE_DATA` turns on when
# `VITE_FIREBASE_API_KEY` does NOT contain `DemoKeyReplaceWithYourOwn`.
